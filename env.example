# ============================================================
# NeuraOS — Environment Variable Reference
#
# Copy this file to .env and fill in your values:
#   cp env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# ── Server ────────────────────────────────────────────────────
NEURAOS_PORT=8080
NEURAOS_BIND=0.0.0.0
NEURAOS_CONFIG=config/default.toml
NEURAOS_LOG=info
# Master API key protecting all HTTP endpoints
# Generate with: openssl rand -hex 32
NEURAOS_API_KEY=

# ── LLM Provider API Keys ─────────────────────────────────────
# Tier 1 — Frontier
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Tier 2 — High-performance
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
XAI_API_KEY=

# Tier 3 — Routing / aggregation
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
PERPLEXITY_API_KEY=

# Tier 4 — Cloud providers
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
GOOGLE_APPLICATION_CREDENTIALS=

# Tier 5 — Embeddings
VOYAGE_API_KEY=
JINA_API_KEY=

# ── Databases ─────────────────────────────────────────────────
# PostgreSQL — audit log / relational store
DATABASE_URL=postgresql://neuraos:neuraos@localhost:5432/neuraos
POSTGRES_PASSWORD=neuraos

# Redis — cache + pub/sub
REDIS_URL=redis://localhost:6379

# Qdrant — vector store for semantic memory
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Memory ────────────────────────────────────────────────────
NEURAOS_DATA_DIR=data
NEURAOS_SQLITE_PATH=data/memory.db

# ── Security ──────────────────────────────────────────────────
# Ed25519 private key for signing agent manifests (hex, 64 chars)
NEURAOS_SIGNING_KEY=
# JWT secret for session tokens
# Generate with: openssl rand -hex 64
NEURAOS_JWT_SECRET=
# TLS certificate and key paths (leave empty for plain HTTP)
NEURAOS_TLS_CERT=
NEURAOS_TLS_KEY=

# ── Observability ─────────────────────────────────────────────
# OpenTelemetry OTLP endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=neuraos
# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ── Integrations ──────────────────────────────────────────────
# Slack (for SendSlack tool)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Email (for SendEmail tool — SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Web search (for WebSearch tool)
SERPAPI_KEY=
TAVILY_API_KEY=
BING_SEARCH_KEY=

# GitHub (for GitDiff / GitClone tools)
GITHUB_TOKEN=

# ── Feature Flags ─────────────────────────────────────────────
NEURAOS_ENABLE_WASM_TOOLS=false
NEURAOS_ENABLE_MCP=false
NEURAOS_ENABLE_GRAPH_MEMORY=true
NEURAOS_ENABLE_TELEMETRY=true
NEURAOS_PRELOAD_AGENTS=true
